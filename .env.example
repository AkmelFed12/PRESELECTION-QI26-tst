# ============================================================
# Variables d'environnement — Quiz Islamique 2026
# ============================================================
# ⚠️ IMPORTANT: Copier ce fichier en .env et remplir les valeurs réelles
# NE JAMAIS commit .env avec les vraies valeurs!
# ============================================================

# ==================== 🔐 CREDENTIALS (KEEP SECRET!) ====================

# Database URL (local default: postgresql://localhost:5432/quiz26)
# For production use DATABASE_EXTERNAL_URL if on Render
DATABASE_URL=postgresql://postgres:password@localhost:5432/quiz26
DATABASE_EXTERNAL_URL=

# Admin credentials (update these immediately after first login!)
ADMIN_USERNAME=asaa2026
ADMIN_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
ADMIN_USERNAME_ALT=admin_alt
ADMIN_PASSWORD_ALT=CHANGE_ME_TO_ANOTHER_STRONG_PASSWORD

# ==================== EMAIL (OPTIONAL) ====================
# If configured, sends notifications on registration and contact forms

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-not-regular-password
SMTP_FROM=noreply@quizislamique.com
SMTP_TO=admin@quizislamique.com

# ==================== CLOUDINARY (OPTIONAL) ====================
# For candidate photo uploads and management

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=quiz-islamique

# ==================== SERVER CONFIG ====================

# Port (default: 10000)
PORT=10000

# Node environment (development, test, production)
NODE_ENV=development

# Site URL (for emails and redirects)
SITE_URL=http://localhost:10000
CORS_ORIGIN=http://localhost:3000

# ==================== FEATURES & LIMITS ====================

# Maximum upload file size (in bytes, default: 3MB)
MAX_UPLOAD_BYTES=3145728

# Rate limiting
# RATE_LIMIT_REGISTER=10         # Registrations per 5 min
# RATE_LIMIT_CONTACT=8           # Contact forms per 5 min
# RATE_LIMIT_VOTE=30             # Votes per 5 min

# ==================== OPTIONAL: WHATSAPP ====================

ADMIN_WHATSAPP=2250150070083

# ==================== OPTIONAL: DATABASE POOL ====================

# Use database connection pool (for high-load production)
USE_DB_POOL=0

# ==================== DEFAULT VALUES ====================

# Default country for candidates
DEFAULT_COUNTRY=COTE D'IVOIRE

# Default member password on creation
MEMBER_DEFAULT_PASSWORD=ASAA2026!

# ==================== RENDER DEPLOYMENT (if using Render) ====================

# Render region if needed
RENDER_DB_REGION=oregon

# ==================== SECURITY NOTES ====================
# ✅ DO: Use strong, unique passwords (20+ characters, mixed case, numbers, symbols)
# ✅ DO: Rotate admin passwords regularly
# ✅ DO: Use app-specific passwords for Gmail (not your account password)
# ✅ DO: Keep .env in .gitignore and never commit it
# ❌ DON'T: Share .env file via email, Slack, or Git
# ❌ DON'T: Use simple passwords like "password123"
# ❌ DON'T: Commit real credentials to version control

